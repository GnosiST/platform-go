        "capability": "session",
        "kind": "demo",
        "productionUsage": "local-harness-only",
        "adapterBoundary": "built-in-demo-login",
        "audiences": ["admin", "app"],
        "configKeys": [],
        "requiredControls": ["audit-redaction", "provider-specific-error-normalization"],
        "requiresSecretOwner": false,
        "rotationRunbookRequired": false,
