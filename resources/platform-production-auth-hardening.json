        "requiredControls": ["secret-rotation-plan", "provider-subject-redaction", "raw-provider-subject-never-in-response", "raw-provider-subject-never-in-audit", "configured-provider-only-login", "provider-specific-error-normalization"],
        "requiresSecretOwner": true,
