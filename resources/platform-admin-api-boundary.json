{
  "$schema": "https://platform-go.local/schemas/platform-admin-api-boundary.json",
  "capturedAt": "2026-07-07",
  "purpose": "Machine-checkable admin API boundary and query-security contract. Admin UI code must use the platform API client, list queries must use structured POST bodies, and backend query execution must stay schema-whitelisted and injection-safe.",
  "reference": {
    "project": "zshenmez",
    "sourceSignals": [
      "admin/src/apiBoundary.ts",
      "admin/src/querySecurity.ts",
      "admin/scripts/check-api-boundary.mjs",
      "api/internal/httpapi/query_security_test.go"
    ],
    "promotionDecision": "foundation-gate"
  },
  "adminSourceBoundary": {
    "root": "admin/src",
    "allowedDirectFetchFiles": [
      "admin/src/platform/api/client.ts"
    ],
    "ignoredFiles": [
      "admin/src/platform/i18n.ts"
    ],
    "forbiddenRequestTargets": [
      "/api/app",
      "/app",
      "encoded app API path",
      "absolute admin URL"
    ],
    "forbiddenCollectionQueryTransport": [
      "?filters",
      "filters["
    ]
  },
  "querySecurity": {
    "transport": "POST /api/admin/resources/:resource/query",
    "payload": "structured-json",
    "rawSQLAllowed": false,
    "sqlLikeInputPolicy": "parse-to-structured-conditions-or-treat-as-literal-value",
    "fieldWhitelistSource": "resource schema",
    "sensitivityPolicySource": "capability manifest",
    "fieldNameInferenceAllowed": false,
    "encryptedFieldQueryPolicy": "declared-blind-index-exact-match-only",
    "encryptedFieldSortAllowed": false,
    "sortWhitelistRequired": true,
    "maxValueLength": 256,
    "operators": [
      "contains",
      "=",
      "!=",
      ">",
      ">=",
      "<",
      "<="
    ]
  },
  "requiredSourceSnippets": [
    {
      "path": "admin/src/platform/api/client.ts",
      "contains": "export function queryAdminResource"
    },
    {
      "path": "admin/src/platform/api/client.ts",
      "contains": "`/admin/resources/${resource}/query`"
    },
    {
      "path": "admin/src/platform/api/client.ts",
      "contains": "method: \"POST\""
    },
    {
      "path": "admin/src/platform/api/client.ts",
      "contains": "export function getAdminSettingsRuntime"
    },
    {
      "path": "admin/src/platform/api/client.ts",
      "contains": "\"/admin/settings\""
    },
    {
      "path": "admin/src/platform/api/client.ts",
      "contains": "export function updateAdminSettingsResource"
    },
    {
      "path": "admin/src/platform/api/client.ts",
      "contains": "export function validateAdminSettingsResourceConfig"
    },
    {
      "path": "admin/src/platform/api/client.ts",
      "contains": "export function testConnectAdminSettingsResource"
    },
    {
      "path": "admin/src/platform/api/client.ts",
      "contains": "export function testSendMessageCenter"
    },
    {
      "path": "admin/src/platform/api/client.ts",
      "contains": "\"/admin/message-center/test-send\""
    },
    {
      "path": "internal/platform/httpapi/settings.go",
      "contains": "func (s *Server) adminSettingsRuntime"
    },
    {
      "path": "internal/platform/httpapi/settings.go",
      "contains": "s.projectAdminResourceRecords"
    },
    {
      "path": "internal/platform/httpapi/settings.go",
      "contains": "func (s *Server) adminSettingsValidateConfig"
    },
    {
      "path": "internal/platform/httpapi/settings.go",
      "contains": "func (s *Server) adminSettingsTestConnection"
    },
    {
      "path": "internal/platform/httpapi/message_center.go",
      "contains": "func (s *Server) adminMessageCenterTestSend"
    },
    {
      "path": "internal/platform/httpapi/message_center.go",
      "contains": "notification.RedactMessageTarget"
    },
    {
      "path": "admin/src/platform/refine/dataProvider.ts",
      "contains": "const result = await queryAdminResource"
    },
    {
      "path": "admin/src/platform/refine/dataProvider.ts",
      "contains": "meta?.conditions"
    },
    {
      "path": "admin/src/platform/refine/dataProvider.ts",
      "contains": "sortersToQuerySort"
    },
    {
      "path": "admin/src/platform/resources/GenericResourceConsole.tsx",
      "contains": "queryOperatorToAdminOperator"
    },
    {
      "path": "admin/src/platform/resources/GenericResourceConsole.tsx",
      "contains": "dictionary.advancedFilters"
    },
    {
      "path": "internal/platform/adminresource/query.go",
      "contains": "query field is not declared by resource schema"
    },
    {
      "path": "internal/platform/adminresource/query.go",
      "contains": "encrypted field supports only exact-match queries"
    },
    {
      "path": "internal/platform/adminresource/query.go",
      "contains": "encrypted field cannot be sorted"
    },
    {
      "path": "internal/platform/adminresource/query.go",
      "contains": "maxQueryValueLength  = 256"
    },
    {
      "path": "internal/platform/adminresource/store_test.go",
      "contains": "TestStoreQueryRejectsUnsafeConditions"
    },
    {
      "path": "internal/platform/adminresource/store_test.go",
      "contains": "TestStoreQueryTreatsSQLLikeValuesAsLiterals"
    },
    {
      "path": "internal/platform/httpapi/server_test.go",
      "contains": "TestAdminResourceQueryEndpointRejectsUnsafeField"
    },
    {
      "path": "resources/generated/openapi.admin.json",
      "contains": "raw input must never be concatenated into SQL"
    }
  ],
  "requiredValidators": [
    "scripts/validate-platform-admin-api-boundary.mjs"
  ],
  "requiredTests": [
    "scripts/platform-admin-api-boundary.test.mjs"
  ]
}
