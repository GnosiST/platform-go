{
  "$schema": "https://platform-go.local/schemas/platform-capability-contracts.json",
  "capturedAt": "2026-07-08",
  "contractVersion": "0.1.0",
  "purpose": "Machine-checkable governance contract for plugin-style platform capabilities. Runtime manifests stay lean; this file classifies real platform capabilities, default/profile policy, replaceability and business-neutral boundaries.",
  "policies": {
    "runtimeManifestMutation": "forbidden",
    "governanceMetadataLocation": "resources/platform-capability-contracts.json",
    "defaultProfile": "platform-default",
    "businessCapabilitiesSource": "resources/platform-capability-profiles.json businessCapabilities",
    "defaultProfileBusinessCapabilitiesAllowed": false,
    "profilePolicies": [
      "default-enabled",
      "default-development-only",
      "profile-only",
      "business-external-only"
    ],
    "classifications": [
      "foundation-core",
      "foundation-default",
      "optional-platform",
      "local-demo",
      "external-business-boundary"
    ],
    "sourceKinds": [
      "core-manifest",
      "platform-extension-manifest",
      "external-business-boundary"
    ]
  },
  "capabilities": [
    {
      "id": "dictionary",
      "label": { "zh": "字典与地址码", "en": "Dictionary And Area Codes" },
      "classification": "foundation-core",
      "profilePolicy": "default-enabled",
      "source": { "kind": "core-manifest", "package": "internal/platform/core" },
      "ownership": "platform-core",
      "boundary": "Shared master data, dictionary values and area codes. It must remain business-neutral and reusable by tenant, identity and optional capabilities.",
      "replaceability": "replace-through-manifest-extension",
      "requiredInProfiles": ["minimal-admin", "platform-default"],
      "dependencies": [],
      "adminResources": ["area-codes", "dictionaries", "dictionary-parameters"],
      "docs": ["docs/platform-capability-development.md", "docs/platform-foundation-task-map.md"]
    },
    {
      "id": "tenant",
      "label": { "zh": "租户", "en": "Tenant" },
      "classification": "foundation-core",
      "profilePolicy": "default-enabled",
      "source": { "kind": "core-manifest", "package": "internal/platform/core" },
      "ownership": "platform-core",
      "boundary": "Tenant master data and tenant-level isolation hints. It does not own business organizations or workflows.",
      "replaceability": "replace-through-manifest-extension",
      "requiredInProfiles": ["minimal-admin", "platform-default"],
      "dependencies": ["dictionary"],
      "adminResources": ["tenants"],
      "docs": ["docs/platform-capability-development.md", "docs/platform-foundation-task-map.md"]
    },
    {
      "id": "identity",
      "label": { "zh": "身份与组织", "en": "Identity And Organization" },
      "classification": "foundation-core",
      "profilePolicy": "default-enabled",
      "source": { "kind": "core-manifest", "package": "internal/platform/core" },
      "ownership": "platform-core",
      "boundary": "Users, app identities and generic organization units. Business-specific personnel workflows must attach through optional capabilities.",
      "replaceability": "replace-through-adapter-or-manifest-extension",
      "requiredInProfiles": ["minimal-admin", "platform-default"],
      "dependencies": ["tenant"],
      "adminResources": ["app-identities", "org-units", "users"],
      "docs": ["docs/platform-capability-development.md", "docs/platform-foundation-task-map.md"]
    },
    {
      "id": "session",
      "label": { "zh": "会话", "en": "Session" },
      "classification": "foundation-core",
      "profilePolicy": "default-enabled",
      "source": { "kind": "core-manifest", "package": "internal/platform/core" },
      "ownership": "platform-core",
      "boundary": "Admin and app session records, demo provider registration for local development and session app routes.",
      "replaceability": "replace-through-auth-adapter",
      "requiredInProfiles": ["minimal-admin", "platform-default"],
      "dependencies": ["identity"],
      "adminResources": ["sessions"],
      "appRoutes": ["GET /api/app/session/current", "POST /api/app/auth/login", "POST /api/app/auth/logout"],
      "authProviders": ["demo"],
      "docs": ["docs/platform-auth.md", "docs/platform-capability-development.md"]
    },
    {
      "id": "rbac",
      "label": { "zh": "权限与角色", "en": "RBAC" },
      "classification": "foundation-core",
      "profilePolicy": "default-enabled",
      "source": { "kind": "core-manifest", "package": "internal/platform/core" },
      "ownership": "platform-core",
      "boundary": "Roles, role groups and permission catalog. Backend authorization remains authoritative; menus are visibility hints.",
      "replaceability": "replace-through-authorizer-adapter",
      "requiredInProfiles": ["minimal-admin", "platform-default"],
      "dependencies": ["identity", "tenant"],
      "adminResources": ["permissions", "role-groups", "roles"],
      "docs": ["docs/admin-rbac-menu.md", "docs/platform-capability-development.md"]
    },
    {
      "id": "menu",
      "label": { "zh": "动态菜单", "en": "Dynamic Menu" },
      "classification": "foundation-core",
      "profilePolicy": "default-enabled",
      "source": { "kind": "core-manifest", "package": "internal/platform/core" },
      "ownership": "platform-core",
      "boundary": "Admin navigation resources, route metadata and cache flags. It must not encode business-only menus.",
      "replaceability": "replace-through-manifest-extension",
      "requiredInProfiles": ["minimal-admin", "platform-default"],
      "dependencies": ["rbac"],
      "adminResources": ["menus"],
      "docs": ["docs/admin-rbac-menu.md", "docs/platform-capability-development.md"]
    },
    {
      "id": "api-resource",
      "label": { "zh": "API 资源治理", "en": "API Resource Governance" },
      "classification": "foundation-default",
      "profilePolicy": "default-enabled",
      "source": { "kind": "core-manifest", "package": "internal/platform/core" },
      "ownership": "platform-core",
      "boundary": "API resource catalog, OpenAPI docs and permission-code governance for reusable platform and attached capabilities.",
      "replaceability": "replace-through-manifest-extension",
      "requiredInProfiles": ["platform-default"],
      "dependencies": ["rbac"],
      "adminResources": ["api-docs", "api-resources"],
      "docs": ["docs/admin-resource-schema.md", "docs/platform-capability-development.md"]
    },
    {
      "id": "audit",
      "label": { "zh": "审计日志", "en": "Audit Logs" },
      "classification": "foundation-default",
      "profilePolicy": "default-enabled",
      "source": { "kind": "core-manifest", "package": "internal/platform/core" },
      "ownership": "platform-core",
      "boundary": "Operation, login and error audit records shared across platform capabilities. Business audit extensions must attach explicitly.",
      "replaceability": "replace-through-audit-adapter",
      "requiredInProfiles": ["platform-default"],
      "dependencies": ["identity", "tenant"],
      "adminResources": ["audit-logs", "error-logs", "login-logs"],
      "docs": ["docs/platform-capability-development.md", "docs/platform-foundation-task-map.md"]
    },
    {
      "id": "wechat-login",
      "label": { "zh": "微信登录", "en": "WeChat Login" },
      "classification": "foundation-default",
      "profilePolicy": "default-enabled",
      "source": { "kind": "core-manifest", "package": "internal/platform/core" },
      "ownership": "platform-auth-provider",
      "boundary": "WeChat auth-provider declaration and configuration keys. It supplies reusable login infrastructure, not app-specific onboarding workflow.",
      "replaceability": "replace-through-auth-provider",
      "requiredInProfiles": ["platform-default"],
      "dependencies": ["audit", "identity", "session"],
      "authProviders": ["wechat"],
      "docs": ["docs/platform-auth.md", "docs/platform-capability-development.md"]
    },
    {
      "id": "parameter",
      "label": { "zh": "参数与品牌", "en": "Parameters And Branding" },
      "classification": "foundation-default",
      "profilePolicy": "default-enabled",
      "source": { "kind": "core-manifest", "package": "internal/platform/core" },
      "ownership": "platform-core",
      "boundary": "Reusable settings, parameters and brand configuration. Business feature flags must attach through their own capability.",
      "replaceability": "replace-through-config-adapter",
      "requiredInProfiles": ["platform-default"],
      "dependencies": ["audit", "tenant"],
      "adminResources": ["branding", "parameters", "settings"],
      "docs": ["docs/platform-branding.md", "docs/platform-capability-development.md"]
    },
    {
      "id": "file-storage",
      "label": { "zh": "文件存储", "en": "File Storage" },
      "classification": "foundation-default",
      "profilePolicy": "default-enabled",
      "source": { "kind": "core-manifest", "package": "internal/platform/core" },
      "ownership": "platform-storage",
      "boundary": "Generic file metadata, upload/download app routes and storage port. Domain-specific file semantics stay in the consuming capability.",
      "replaceability": "replace-through-storage-adapter",
      "requiredInProfiles": ["platform-default"],
      "dependencies": ["audit", "identity", "parameter", "tenant"],
      "adminResources": ["files"],
      "appRoutes": ["GET /api/app/files/:id/content", "POST /api/app/files"],
      "docs": ["docs/platform-cache.md", "docs/platform-capability-development.md"]
    },
    {
      "id": "admin-shell",
      "label": { "zh": "后台 Shell", "en": "Admin Shell" },
      "classification": "foundation-core",
      "profilePolicy": "default-enabled",
      "source": { "kind": "core-manifest", "package": "internal/platform/core" },
      "ownership": "platform-admin",
      "boundary": "Reusable admin overview, capability console and shell integration. It hosts resources declared by capabilities rather than owning business modules.",
      "replaceability": "replace-through-admin-shell-extension",
      "requiredInProfiles": ["minimal-admin", "platform-default"],
      "dependencies": ["identity", "menu", "rbac", "session"],
      "adminResources": ["capabilities", "overview"],
      "docs": ["docs/admin-ui-foundation.md", "docs/platform-capability-development.md"]
    },
    {
      "id": "demo-data",
      "label": { "zh": "演示数据", "en": "Demo Data" },
      "classification": "local-demo",
      "profilePolicy": "default-development-only",
      "productionPolicy": "forbidden",
      "source": { "kind": "core-manifest", "package": "internal/platform/core" },
      "ownership": "platform-demo",
      "boundary": "Declarative local demo data. Production runtime must reject this capability even if development defaults include it.",
      "replaceability": "replace-through-demo-dataset",
      "requiredInProfiles": ["platform-default"],
      "dependencies": ["admin-shell", "tenant"],
      "adminResources": ["demo-data"],
      "demoDataSets": ["platform-demo-tenants"],
      "docs": ["docs/platform-demo-data.md", "docs/platform-capability-development.md"]
    },
    {
      "id": "system-admin",
      "label": { "zh": "系统管理", "en": "System Administration" },
      "classification": "foundation-default",
      "profilePolicy": "default-enabled",
      "source": { "kind": "core-manifest", "package": "internal/platform/core" },
      "ownership": "platform-operations",
      "boundary": "Monitoring, version and API token resources for platform operations. It must not include business process dashboards.",
      "replaceability": "replace-through-operations-adapter",
      "requiredInProfiles": ["platform-default"],
      "dependencies": ["admin-shell", "api-resource", "audit", "dictionary", "parameter"],
      "adminResources": ["api-tokens", "monitoring", "versions"],
      "docs": ["docs/platform-capability-development.md", "docs/platform-foundation-task-map.md"]
    },
    {
      "id": "app-phone",
      "label": { "zh": "App 手机绑定", "en": "App Phone Binding" },
      "classification": "optional-platform",
      "profilePolicy": "profile-only",
      "source": { "kind": "platform-extension-manifest", "package": "internal/platform/core" },
      "ownership": "platform-identity-extension",
      "boundary": "Reusable app phone verification and binding. It is excluded from default and enabled only by app-ready profiles.",
      "replaceability": "replace-through-auth-provider-or-identity-extension",
      "includedInProfiles": ["platform-app-ready"],
      "excludedFromProfiles": ["minimal-admin", "platform-default"],
      "dependencies": ["audit", "identity", "session"],
      "adminResources": ["app-phone-bindings", "app-phone-verifications"],
      "appRoutes": ["POST /api/app/identity/phone-bindings", "POST /api/app/identity/phone-verifications"],
      "docs": ["docs/platform-auth.md", "docs/platform-capability-development.md"]
    },
    {
      "id": "personnel",
      "label": { "zh": "人员与岗位", "en": "Personnel And Positions" },
      "classification": "optional-platform",
      "profilePolicy": "profile-only",
      "source": { "kind": "platform-extension-manifest", "package": "internal/platform/core" },
      "ownership": "platform-governance-extension",
      "boundary": "Reusable personnel profiles, positions and assignments. It stays optional so generic tenant/org/user governance remains lightweight.",
      "replaceability": "replace-through-manifest-extension",
      "includedInProfiles": ["platform-personnel-ready"],
      "excludedFromProfiles": ["minimal-admin", "platform-default"],
      "dependencies": ["dictionary", "identity", "tenant"],
      "adminResources": ["personnel-profiles", "position-assignments", "positions"],
      "docs": ["docs/platform-capability-development.md", "docs/platform-foundation-task-map.md"]
    },
    {
      "id": "notification",
      "label": { "zh": "通知", "en": "Notification" },
      "classification": "optional-platform",
      "profilePolicy": "profile-only",
      "source": { "kind": "platform-extension-manifest", "package": "internal/platform/core" },
      "ownership": "platform-operations-extension",
      "boundary": "Reusable notification templates, records and delivery ledgers without binding to one business domain.",
      "replaceability": "replace-through-notification-adapter",
      "includedInProfiles": ["platform-notification-ready"],
      "excludedFromProfiles": ["minimal-admin", "platform-default"],
      "dependencies": ["audit", "identity", "tenant"],
      "adminResources": ["notification-deliveries", "notification-templates", "notifications"],
      "docs": ["docs/platform-capability-development.md", "docs/platform-foundation-task-map.md"]
    },
    {
      "id": "job",
      "label": { "zh": "任务调度", "en": "Job Scheduling" },
      "classification": "optional-platform",
      "profilePolicy": "profile-only",
      "source": { "kind": "platform-extension-manifest", "package": "internal/platform/core" },
      "ownership": "platform-operations-extension",
      "boundary": "Reusable job definitions, run records and attempt ledgers. Worker engines and business jobs attach separately.",
      "replaceability": "replace-through-job-runner-adapter",
      "includedInProfiles": ["platform-job-ready"],
      "excludedFromProfiles": ["minimal-admin", "platform-default"],
      "dependencies": ["audit", "identity", "tenant"],
      "adminResources": ["job-definitions", "job-run-attempts", "job-runs"],
      "docs": ["docs/platform-capability-development.md", "docs/platform-foundation-task-map.md"]
    },
    {
      "id": "policy-review",
      "label": { "zh": "权限评审", "en": "Policy Review" },
      "classification": "optional-platform",
      "profilePolicy": "profile-only",
      "source": { "kind": "platform-extension-manifest", "package": "internal/platform/core" },
      "ownership": "platform-governance-extension",
      "boundary": "Reusable permission review workflow for platform governance. It is enterprise-profile only and not a business approval workflow.",
      "replaceability": "replace-through-audit-workflow-extension",
      "includedInProfiles": ["enterprise-governance"],
      "excludedFromProfiles": ["minimal-admin", "platform-default"],
      "dependencies": ["audit", "identity", "rbac"],
      "adminResources": ["policy-reviews"],
      "docs": ["docs/platform-capability-development.md", "docs/platform-foundation-task-map.md"]
    },
    {
      "id": "external-business-capability",
      "label": { "zh": "外部业务能力", "en": "External Business Capability" },
      "classification": "external-business-boundary",
      "profilePolicy": "business-external-only",
      "source": { "kind": "external-business-boundary", "package": "internal/apps/<app>" },
      "ownership": "business-application",
      "boundary": "Placeholder boundary for downstream business capabilities. It must stay outside platform defaults and must not be implemented inside the reusable foundation.",
      "replaceability": "owned-by-consuming-application",
      "excludedFromProfiles": ["minimal-admin", "platform-default", "platform-app-ready", "platform-personnel-ready", "platform-notification-ready", "platform-job-ready", "enterprise-governance"],
      "docs": ["docs/platform-capability-development.md", "docs/platform-foundation-task-map.md"]
    }
  ],
  "validators": [
    "scripts/validate-platform-capability-contracts.mjs"
  ],
  "tests": [
    "scripts/platform-capability-contracts.test.mjs"
  ]
}
