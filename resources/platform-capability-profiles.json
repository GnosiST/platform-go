{
  "$schema": "https://platform-go.local/schemas/platform-capability-profiles.json",
  "runtimeDefault": "platform-default",
  "businessCapabilities": [
    "external-business-capability"
  ],
  "profiles": [
    {
      "id": "minimal-admin",
      "label": {
        "zh": "最小后台底座",
        "en": "Minimal Admin Foundation"
      },
      "purpose": "Smallest reusable admin foundation for tenant, identity, RBAC, menu and shell work.",
      "capabilities": [
        "dictionary",
        "tenant",
        "identity",
        "session",
        "rbac",
        "menu",
        "admin-shell"
      ],
      "mustIncludeResources": [
        "area-codes",
        "tenants",
        "org-units",
        "users",
        "roles",
        "role-groups",
        "permissions",
        "menus",
        "sessions",
        "capabilities",
        "overview"
      ],
      "mustExcludeCapabilities": [
        "external-business-capability",
        "admin-oidc",
        "policy-review",
        "personnel",
        "notification",
        "job",
        "file-storage",
        "demo-data",
        "system-admin"
      ]
    },
