{
  "$schema": "https://platform-go.local/schemas/platform-task-execution-audit.json",
  "capturedAt": "2026-07-16",
  "purpose": "Machine-checkable execution audit for the active platform foundation goal: every task node, dependency, resource lock, parallel batch, future runtime-promotion gate and visual workflow gate remains explicit after foundation implementation closes.",
  "taskGraph": "resources/platform-foundation-task-graph.json",
  "alignmentAudit": "resources/platform-foundation-alignment-audit.json",
  "engineeringCapability": "task-dependency-governance",
  "statusPolicy": {
    "implementedRequiresEvidence": true,
    "unfinishedRequiresStatusReason": true,
    "unfinishedRequiresCompletionGate": true,
    "futureTaskNodesMustNotDisappear": true,
    "visualTasksRequireProductDesign": true,
    "resourceLocksMustDeclarePolicies": true,
    "parallelBatchesMustAvoidResourceLockGroups": true,
    "parallelBatchesMustAvoidResourceLockConflicts": true,
    "parallelBatchesMustAvoidDependencyPaths": true,
    "releaseLanePartitionRequired": true
  },
  "requiredUnfinishedNodes": [
    "multi-datasource-contract-and-runtime",
    "tenant-placement-and-request-routing",
    "datasource-read-write-routing",
    "sharding-and-tenant-migration",
    "federated-read-query",
    "xa-optional-adapter",
    "database-certification-matrix",
    "transactional-outbox-and-one-mq-adapter",
    "asynchronous-search-projection"
  ],
  "knownPromotionBlockers": [
    {
      "taskId": "production-auth-provider-hardening",
      "runtimeMutationBlockedWhile": [
        "resources/platform-production-auth-hardening.json sessionCredentialPolicy.refreshTokenFamily.defaultRuntime is disabled",
        "resources/platform-production-auth-hardening.json productionPromotionApprovalPackage.status is blocked"
      ],
      "requiredEvidenceBeforePromotion": [
        "runtime test output bundle including refresh-token-family tests",
        "token-family revocation evidence",
        "redis session invalidation convergence evidence",
        "rotation replay audit evidence",
        "security-owner approval",
        "platform-architect approval",
        "operations-owner approval",
        "structured approval evidence package",
        "provider rotation runbook",
        "rollback plan",
        "audit redaction sample",
        "external absolute artifact URI evidence"
      ]
    },
    {
      "taskId": "source-writing-codegen-promotion",
      "runtimeMutationBlockedWhile": [
        "resources/platform-codegen-source-writing-readiness.json mode.sourceWriting is disabled",
        "resources/platform-codegen-source-writing-readiness.json sourceWritingApprovalPackage.status is blocked",
        "resources/generated/admin-scaffold-promotion-review.json manualReview.decision is not-approved"
      ],
      "requiredEvidenceBeforePromotion": [
        "source-writing architecture spec",
        "platform-architect approval",
        "codegen-owner approval",
        "runtime-owner approval",
        "approved promotion review packet",
        "reviewed diff",
        "target-family test mapping",
        "target-family test output",
        "runtime target owner approval",
        "rollback plan",
        "structured source-writing approval evidence package",
        "external absolute artifact URI evidence"
      ]
    }
  ],
  "requiredValidators": [
    "scripts/validate-platform-task-execution-audit.mjs",
    "scripts/validate-platform-foundation-task-graph.mjs",
    "scripts/validate-platform-foundation-alignment.mjs",
    "scripts/validate-platform-engineering-capabilities.mjs",
    "scripts/validate-platform-admin-api-boundary.mjs",
    "scripts/validate-platform-app-client-api-boundary.mjs",
    "scripts/validate-platform-file-storage-experience.mjs",
    "scripts/validate-platform-refresh-token-family-promotion.mjs",
    "scripts/validate-platform-goal-completion-audit.mjs",
    "scripts/validate-platform-node-closeout-audit.mjs",
    "scripts/validate-platform-data-lifecycle-retention.mjs",
    "scripts/validate-platform-service-contract-standard.mjs",
    "scripts/validate-platform-service-object-runtime.mjs",
    "scripts/validate-platform-integration-ports.mjs",
    "scripts/validate-platform-organization-rbac-menu-contract.mjs",
    "scripts/validate-platform-sensitive-data-migration.mjs",
    "scripts/validate-platform-objective-conformance.mjs",
    "scripts/validate-platform-promotion-evidence-templates.mjs",
    "scripts/validate-platform-promotion-evidence-package.mjs"
  ],
  "requiredTests": [
    "scripts/platform-task-execution-audit.test.mjs",
    "scripts/platform-data-lifecycle-retention.test.mjs",
    "scripts/platform-sensitive-data-migration.test.mjs",
    "scripts/platform-service-contract-standard.test.mjs",
    "scripts/platform-service-object-runtime.test.mjs",
    "scripts/platform-integration-ports.test.mjs",
    "scripts/platform-organization-rbac-menu-contract.test.mjs"
  ]
}
