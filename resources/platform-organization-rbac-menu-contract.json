  "identityContract": {
    "userScopeField": "scopeType",
    "userScopes": ["platform", "tenant"],
    "tenantUser": {
      "orgUnitCode": "required",
      "tenantCode": "server-derived-redundantly-persisted-read-only",
      "roleSource": "effective-organization-role-pool"
    },
    "platformUser": {
      "orgUnitCode": "must-be-empty",
      "tenantCode": "must-be-empty",
      "roleSource": "enabled-platform-role-groups"
    },
    "allWritePaths": ["create", "update", "bulk-assign", "import", "service-command", "delete", "restore", "purge"],
    "clientPhysicalRoutingInputs": "forbidden"
  },
  "relationalContract": {
    "codeIdentityPolicy": "globally-unique-stable-codes-retained-for-compatibility",
    "tables": [
      {
        "logicalName": "role_groups",
        "physicalName": "platform_admin_role_groups",
        "changes": [
          "add scope_type platform|tenant",
          "add nullable tenant_code",
          "require tenant_code exactly when scope_type=tenant",
          "remove parent_code after migration",
          "keep authorization fields forbidden"
        ]
      },
      {
        "logicalName": "roles",
        "physicalName": "platform_admin_roles",
        "changes": [
          "normalize required group_code",
          "derive role scope and tenant from role group",
          "keep permissions deny_permissions and data_scope role-owned"
        ]
      },
      {
        "logicalName": "org_unit_role_groups",
        "physicalName": "platform_admin_org_unit_role_groups",
        "primaryKey": ["org_unit_code", "role_group_code"],
        "invariants": [
          "organization and role group are enabled",
          "role group scope is tenant",
          "organization tenant equals role group tenant",
          "platform role groups cannot be bound"
        ]
      },
      {
        "logicalName": "users",
        "physicalName": "platform_admin_users",
        "changes": [
          "normalize scope_type tenant|platform",
          "normalize primary org_unit_code",
          "persist tenant_code only as a server-derived invariant",
          "reject client tenant changes"
        ]
      },
      {
        "logicalName": "user_roles",
        "physicalName": "platform_admin_user_roles",
        "invariants": [
          "tenant user roles belong to the effective organization role pool",
          "platform user roles belong to enabled platform role groups"
        ]
      },
      {
        "logicalName": "menus",
        "physicalName": "platform_admin_menus",
        "changes": [
          "add required node_type directory|page",
          "normalize parent_code",
          "keep legacy permission read-only during migration",
          "require page nodes to be leaves"
        ]
      },
      {
        "logicalName": "role_menu",
        "physicalName": "platform_admin_role_menus",
        "primaryKey": ["role_code", "menu_code"],
        "invariants": [
          "menu_code references an enabled page node",
          "directory visibility is derived from assigned descendant pages",
          "writes use a separate revision and audit action from role permissions"
        ]
      },
      {
        "logicalName": "page_buttons",
        "physicalName": "platform_admin_page_buttons",
        "primaryKey": ["menu_code", "button_key"],
        "invariants": [
          "menu_code references an enabled page node",
          "button_key is stable within the page",
          "permission_code references a page-button permission"
        ]
      },
      {
        "logicalName": "permissions",
        "physicalName": "platform_admin_permissions",
        "changes": [
          "add required resource_type api|page-button",
          "page-button permissions reference one page menu and stable button_key",
          "api permissions retain Casbin method and path enforcement metadata"
        ]
      }
    ]
  },
  "organizationRolePoolContract": {
    "eligibleGroups": "enabled tenant groups directly bound to the selected enabled organization",
    "eligibleRoles": "enabled roles whose required group is eligible",
    "deduplicationKey": "role.code",
