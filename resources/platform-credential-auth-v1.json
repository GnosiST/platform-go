{
  "$schema": "https://platform-go.local/schemas/platform-credential-auth-v1.json",
  "capturedAt": "2026-07-19",
  "contractVersion": "0.1.0",
  "id": "credential-auth",
  "purpose": "Machine-checkable v1 contract for the local credential authentication capability. This package specifies provider modes, dedicated credential stores, challenge boundaries, the first internal service foundation, partial development HTTP/UI runtime and validation gates without making local credential auth production-complete.",
  "runtimeBoundary": {
    "status": "dev-http-runtime-memory-bootstrap",
    "currentLoginRuntime": "demo-oidc-and-configured-app-provider-flow-plus-credential-auth-dev-slice",
    "defaultRuntimeMutation": "forbidden",
    "passwordProviderKindRuntimeAccepted": false,
    "existingPasswordProviderGuardMustRemain": true,
    "productionComplete": false,
    "devRuntimeStorage": "in-memory credential-auth repository seeded from bootstrap admin environment",
    "productionEnablementGate": "production credential-auth remains blocked until a persistent credential repository, vendor SMS adapter policy and security governance package are approved",
    "mustNotChange": [
      "existing demo provider runtime",
      "existing Admin OIDC runtime",
      "existing WeChat/app provider runtime",
      "current POST /api/auth/login demo/OIDC compatibility handling"
    ]
  },
  "capabilityBoundary": {
    "capabilityId": "credential-auth",
    "classification": "optional-platform-capability",
    "businessNeutral": true,
    "dependencies": ["identity", "session", "rbac", "audit", "notification"],
    "extendsCapabilities": [
      {
        "capability": "notification",
        "extension": "sms-channel",
        "reason": "SMS OTP delivery is reusable outside authentication and must not live inside credential-auth storage."
      }
    ],
    "owns": [
      "local credential provider declarations",
      "identifier normalization and hash lookup",
      "password credential verification policy",
      "login challenge transaction policy",
      "SMS OTP transaction policy",
      "login failure counters and lockout policy"
    ],
    "doesNotOwn": [
      "platform user/person identity source",
      "JWT signing or server-side session issuance",
      "post-login RBAC authorization",
      "audit ledger persistence",
      "SMS vendor transport implementation",
      "business-specific registration or onboarding"
    ]
  },
  "providerModes": [
    {
      "id": "username-password",
      "identifierType": "username",
      "secretType": "password",
      "configKey": "PLATFORM_CREDENTIAL_AUTH_USERNAME_PASSWORD",
      "requiresChallengeDecision": true
    },
    {
      "id": "phone-password",
      "identifierType": "phone",
      "secretType": "password",
      "configKey": "PLATFORM_CREDENTIAL_AUTH_PHONE_PASSWORD",
      "requiresChallengeDecision": true
    },
    {
      "id": "email-password",
      "identifierType": "email",
      "secretType": "password",
      "configKey": "PLATFORM_CREDENTIAL_AUTH_EMAIL_PASSWORD",
      "requiresChallengeDecision": true
    },
    {
      "id": "phone-sms-otp",
      "identifierType": "phone",
      "secretType": "sms-otp",
      "configKey": "PLATFORM_CREDENTIAL_AUTH_PHONE_SMS_OTP",
      "requiresChallengeDecision": true
    }
  ],
  "genericRecordValuesPolicy": {
    "passwordCredentialStorageAllowed": false,
    "challengeAnswerStorageAllowed": false,
    "smsOtpStorageAllowed": false,
    "forbiddenCredentialFields": [
      "password",
      "plainPassword",
      "passwordHash",
      "passwordSalt",
      "smsOtp",
      "otpCode",
      "verificationCode",
      "captchaAnswer",
      "challengeAnswer"
    ],
    "allowedGenericUse": "Generic admin resources may reference masked, verified identifiers only when a capability explicitly declares sensitivity, storage and projection policy; credential secrets and challenge proofs require dedicated stores."
  },
  "storageContracts": [
    {
      "id": "auth_identifiers",
      "purpose": "Map normalized identifiers to an admin or app principal without storing raw identifiers.",
      "genericRecordValuesAllowed": false,
      "rawSecretPersistenceAllowed": false,
      "requiredFields": [
        "principalType",
        "principalId",
        "identifierType",
        "identifierHash",
        "maskedIdentifier",
        "verifiedAt",
        "status"
      ],
      "sensitiveFields": ["identifierHash"],
      "rawFieldsForbidden": ["username", "phone", "email"]
    },
    {
      "id": "password_credentials",
      "purpose": "Store Argon2id password verifier metadata for a principal.",
      "genericRecordValuesAllowed": false,
      "rawSecretPersistenceAllowed": false,
      "algorithm": "argon2id",
      "paramsVersionEnv": "PLATFORM_CREDENTIAL_AUTH_ARGON2_PARAMS_VERSION",
      "requiredFields": [
        "principalType",
        "principalId",
        "passwordHash",
        "algorithm",
        "paramsVersion",
        "passwordUpdatedAt",
        "mustChange",
        "failedAttempts",
        "lockedUntil",
        "status"
      ],
      "sensitiveFields": ["passwordHash"],
      "rawFieldsForbidden": ["password", "plainPassword", "passwordSalt"]
    },
    {
      "id": "credential_challenges",
      "purpose": "Store CAPTCHA or slider challenge transaction state for login.",
      "genericRecordValuesAllowed": false,
      "rawSecretPersistenceAllowed": false,
      "requiredFields": [
        "challengeId",
        "kind",
        "purpose",
        "answerDigest",
        "expiresAt",
        "attempts",
        "usedAt",
        "clientFingerprintHash"
      ],
      "sensitiveFields": ["answerDigest", "clientFingerprintHash"],
      "rawFieldsForbidden": ["captchaAnswer", "sliderAnswer", "clientFingerprint"]
    },
    {
      "id": "sms_otp_challenges",
      "purpose": "Store SMS OTP transaction state and one-time consumption metadata.",
      "genericRecordValuesAllowed": false,
      "rawSecretPersistenceAllowed": false,
      "requiredFields": [
        "challengeId",
        "phoneHash",
        "codeDigest",
        "expiresAt",
        "attempts",
        "messageId",
        "usedAt"
      ],
      "sensitiveFields": ["phoneHash", "codeDigest"],
      "rawFieldsForbidden": ["phone", "code", "smsOtp"]
    }
  ],
  "challengeContract": {
    "kinds": ["captcha", "slider"],
    "modes": ["off", "always", "after-failure", "risk-based"],
    "defaultMode": "after-failure",
    "defaultKind": "slider",
    "purpose": "login",
    "ttlSecondsEnv": "PLATFORM_CREDENTIAL_AUTH_CHALLENGE_TTL_SECONDS",
    "proofPersistence": "digest-only",
    "singleUse": true
  },
  "passwordPolicy": {
    "algorithm": "argon2id",
    "paramsVersionEnv": "PLATFORM_CREDENTIAL_AUTH_ARGON2_PARAMS_VERSION",
    "maxAttemptsEnv": "PLATFORM_CREDENTIAL_AUTH_PASSWORD_MAX_ATTEMPTS",
    "lockSecondsEnv": "PLATFORM_CREDENTIAL_AUTH_LOCK_SECONDS",
    "rehashOnParamsUpgrade": true,
    "rawPasswordPersistenceAllowed": false
  },
  "smsOtpPolicy": {
    "transactionEndpoint": "POST /api/auth/sms-otp/start",
    "ttlSecondsEnv": "PLATFORM_AUTH_SMS_OTP_TTL_SECONDS",
    "maxAttemptsEnv": "PLATFORM_AUTH_SMS_OTP_MAX_ATTEMPTS",
    "digestOnly": true,
    "singleUse": true,
    "sendThroughCapability": "notification"
  },
  "notificationSmsBoundary": {
    "capability": "notification",
    "channel": "sms",
    "providerEnv": "PLATFORM_NOTIFICATION_SMS_PROVIDER",
    "loginTemplateEnv": "PLATFORM_NOTIFICATION_SMS_LOGIN_TEMPLATE_ID",
    "requiredAdapters": ["aliyun", "tencent", "mock-local"],
    "productionMockProviderAllowed": false,
    "vendorErrorRedactionRequired": true,
    "deliveryLedgerRequired": true
  },
  "apiContract": {
    "status": "implemented-partial",
    "providerDriven": true,
    "frontEndMustNotHardCodeProviderModes": true,
    "implementedNow": [
      "GET /api/auth/providers includes enabled credential-auth provider declarations",
      "POST /api/auth/sms-otp/start starts phone SMS OTP transactions through notification.sms",
      "POST /api/auth/login accepts structured credential-password and credential-sms-otp requests while preserving demo/OIDC compatibility",
      "Admin login UI renders credential provider modes from discovery"
    ],
    "notProductionComplete": [
      "POST /api/auth/challenges CAPTCHA/slider runtime",
      "persistent file/GORM credential repository",
      "external Aliyun/Tencent SMS adapters and delivery ledger",
      "complete OpenAPI/error-code/audit-redaction/rate-limit governance",
      "production enablement beyond development in-memory bootstrap"
    ],
    "endpoints": [
      {
        "method": "GET",
        "path": "/api/auth/providers",
        "purpose": "Discover enabled credential-auth provider modes alongside existing configured providers."
      },
      {
        "method": "POST",
        "path": "/api/auth/challenges",
        "purpose": "Create CAPTCHA or slider challenge transactions when the provider policy requires them."
      },
      {
        "method": "POST",
        "path": "/api/auth/sms-otp/start",
        "purpose": "Create an SMS OTP transaction and send the login template through notification.sms."
      },
      {
        "method": "POST",
        "path": "/api/auth/login",
        "purpose": "Submit a provider, structured identifier, structured secret and optional challenge proof; successful credential auth delegates session issuance to the existing session boundary."
      }
    ],
    "loginRequestShape": {
      "provider": "phone-password",
      "identifier": {
        "type": "phone",
        "value": "+8613800000000"
      },
      "secret": {
        "type": "password",
        "value": "plain-password"
      },
      "challenge": {
        "id": "challenge-id",
        "kind": "slider",
        "proof": "client-proof"
      }
    },
    "smsLoginRequestShape": {
      "provider": "phone-sms-otp",
      "identifier": {
        "type": "phone",
        "value": "+8613800000000"
      },
      "secret": {
        "type": "sms-otp",
        "transactionId": "otp-id",
        "code": "123456"
      },
      "challenge": {
        "id": "challenge-id",
        "kind": "captcha",
        "proof": "abcd"
      }
    }
  },
  "configurationContract": {
    "capabilityEnvExample": "PLATFORM_CAPABILITIES=identity,session,rbac,audit,notification,credential-auth",
    "featureFlags": [
      "PLATFORM_CREDENTIAL_AUTH_USERNAME_PASSWORD",
      "PLATFORM_CREDENTIAL_AUTH_PHONE_PASSWORD",
      "PLATFORM_CREDENTIAL_AUTH_EMAIL_PASSWORD",
      "PLATFORM_CREDENTIAL_AUTH_PHONE_SMS_OTP"
    ],
    "securityKeys": [
      "PLATFORM_CREDENTIAL_AUTH_IDENTIFIER_HMAC_KEY",
      "PLATFORM_CREDENTIAL_AUTH_BOOTSTRAP_ADMIN_USERNAME",
      "PLATFORM_CREDENTIAL_AUTH_BOOTSTRAP_ADMIN_PASSWORD",
      "PLATFORM_CREDENTIAL_AUTH_BOOTSTRAP_ADMIN_PHONE",
      "PLATFORM_CREDENTIAL_AUTH_BOOTSTRAP_ADMIN_EMAIL",
      "PLATFORM_CREDENTIAL_AUTH_ARGON2_PARAMS_VERSION",
      "PLATFORM_CREDENTIAL_AUTH_PASSWORD_MAX_ATTEMPTS",
      "PLATFORM_CREDENTIAL_AUTH_LOCK_SECONDS",
      "PLATFORM_AUTH_SMS_OTP_TTL_SECONDS",
      "PLATFORM_AUTH_SMS_OTP_MAX_ATTEMPTS",
      "PLATFORM_NOTIFICATION_SMS_PROVIDER",
      "PLATFORM_NOTIFICATION_SMS_LOGIN_TEMPLATE_ID"
    ],
    "productionRejectsMockSms": true
  },
  "implementationPackages": [
    {
      "id": "A-contract-docs-validator",
      "status": "done",
      "scope": "docs/platform-auth.md, docs/platform-capability-development.md, resources/platform-credential-auth-v1.json, scripts/validate-platform-credential-auth-v1.mjs and node tests"
    },
    {
      "id": "B-backend-repositories-services",
      "status": "in-progress",
      "scope": "identifier normalization/hash lookup, Argon2id PHC password verifier, memory repository, password verification service, SMS OTP one-time consumption service and development bootstrap runtime are implemented under internal/platform/credentialauth and internal/platform/bootstrap; file/GORM persistence remains"
    },
    {
      "id": "C-notification-sms-adapters",
      "status": "in-progress",
      "scope": "notification SMS channel port, mock-local sender, provider config validation and production fail-closed rules are implemented under internal/platform/notification and config/bootstrap; external vendor adapters remain"
    },
    {
      "id": "D-auth-api-compatibility",
      "status": "in-progress",
      "scope": "structured credential-password and credential-sms-otp login plus SMS OTP start are wired in internal/platform/httpapi while preserving current demo/OIDC behavior; CAPTCHA/slider challenge runtime remains"
    },
    {
      "id": "E-admin-login-ui",
      "status": "in-progress",
      "scope": "provider-discovery driven Admin login form state is wired for username/password, phone/password, email/password and phone/SMS OTP; full challenge UX and production polish remain"
    },
    {
      "id": "F-security-governance",
      "status": "remaining",
      "scope": "OpenAPI, error codes, audit redaction, rate limits, production env validator and CI gate integration"
    }
  ],
  "docs": [
    "docs/platform-auth.md",
    "docs/platform-capability-development.md"
  ],
  "validators": [
    "scripts/validate-platform-credential-auth-v1.mjs"
  ],
  "tests": [
    "scripts/platform-credential-auth-v1.test.mjs"
  ],
  "minimumAcceptanceCommands": [
    "rtk node scripts/validate-platform-credential-auth-v1.mjs",
    "rtk node --test scripts/platform-credential-auth-v1.test.mjs"
  ]
}
