{
  "$schema": "https://platform-go.local/schemas/platform-objective-conformance.json",
  "capturedAt": "2026-07-16",
  "purpose": "Machine-checkable conformance contract for the persistent reusable platform foundation objective. It keeps stack choices, business-neutral reference use, future promotion gates, visual gates, deployment boundaries and closeout discipline aligned before further implementation continues.",
  "objectiveMode": "persistent-full-scope",
  "approvedStack": {
    "backend": [
      "Gin",
      "GORM",
      "Casbin",
      "JWT"
    ],
    "frontend": [
      "Refine",
      "React",
      "Ant Design"
    ]
  },
  "referenceProjectPolicy": {
    "referenceProject": "resources/reference-snapshot/zshenmez",
    "mode": "reference-only",
    "defaultPlatformBusinessMigration": "forbidden",
    "businessCapabilityOwnership": "external-business-capability",
    "foundationExtractionRequiresDiscovery": true
  },
  "qualityPolicy": {
    "architectureFirst": true,
    "noArtificialStacking": true,
    "noCompromiseImplementation": true,
    "conflictResolution": "objective-wins",
    "businessNeutralFoundation": true
  },
  "taskControlPolicy": {
    "taskGraph": "resources/platform-foundation-task-graph.json",
    "taskExecutionAudit": "resources/platform-task-execution-audit.json",
    "requiresResourceLocks": true,
    "requiresDependencyConflictChecks": true,
    "requiresTaskGraphBeforeNewNode": true,
    "requiredUnfinishedNodes": [
      "multi-datasource-contract-and-runtime",
      "tenant-placement-and-request-routing",
      "datasource-read-write-routing",
      "sharding-and-tenant-migration",
      "federated-read-query",
      "xa-optional-adapter",
      "database-certification-matrix",
      "transactional-outbox-and-one-mq-adapter",
      "asynchronous-search-projection",
      "github-release-publication"
    ]
  },
  "capabilityPolicy": {
    "contract": "resources/platform-capability-contracts.json",
    "profiles": "resources/platform-capability-profiles.json",
    "defaultProfile": "platform-default",
    "businessCapabilityOwnership": "external-business-capability",
    "runtimeManifestMutation": "forbidden",
    "defaultProfileBusinessCapabilitiesAllowed": false
  },
  "visualPolicy": {
    "requiredOrder": ["superpowers:brainstorming", "product-design"],
    "requiredForVisualTasks": true,
    "productDesignRequiredForVisualImplementation": true,
    "i18nRequiredForSharedAdminComponents": true
  },
  "closeoutPolicy": {
    "neatFreakRequiredForEveryNodeCloseout": false,
    "neatFreakInvocationPolicy": {
      "requiredFor": [
        "phase-closeout",
        "major-cross-module-task",
        "release-preparation"
      ],
      "notRequiredFor": [
        "small-node",
        "routine-sub-agent-task"
      ]
    },
    "knowledgeCleanupBeforeNodeCloseout": true,
    "nodeCloseoutAudit": "resources/platform-node-closeout-audit.json",
    "docsRoots": [
      "README.md",
      "AGENTS.md",
      "docs/"
    ]
  },
  "deploymentPolicy": {
    "vercelRequired": false,
    "vercelAdminUsage": "optional-static-admin",
    "selectedTopology": "single-service-production",
    "defaultApiRuntime": "long-lived-service",
    "fullStackVercelGo": "requires-separate-adapter-spec"
  },
  "completionPolicy": {
    "goalCompletionStatus": "not-complete-controlled",
    "mustNotMarkCompleteWhileBlockersActive": true,
    "mustNotSelfCertifyExternalApprovalEvidence": true,
    "controlledBlockers": [
      "multi-datasource-contract-and-runtime",
      "tenant-placement-and-request-routing",
      "datasource-read-write-routing",
      "sharding-and-tenant-migration",
      "federated-read-query",
      "xa-optional-adapter",
      "database-certification-matrix",
      "transactional-outbox-and-one-mq-adapter",
      "asynchronous-search-projection",
      "github-release-publication"
    ]
  },
  "futurePromotionGates": [
    {
      "taskId": "production-auth-provider-hardening",
      "contract": "resources/platform-production-auth-hardening.json",
      "requiredEvidenceBeforeRuntimeMutation": [
        "security-owner approval",
        "platform-architect approval",
        "operations-owner approval",
        "runtime test output bundle including refresh-token-family tests",
        "redis session invalidation convergence evidence",
        "rotation replay audit evidence",
        "structured approval evidence package",
        "external absolute artifact URI evidence"
      ]
    },
    {
      "taskId": "source-writing-codegen-promotion",
      "contract": "resources/platform-codegen-source-writing-readiness.json",
      "requiredEvidenceBeforeRuntimeMutation": [
        "source-writing architecture spec",
        "platform-architect approval",
        "codegen-owner approval",
        "runtime-owner approval",
        "reviewed diff",
        "target-family test output",
        "structured source-writing approval evidence package",
        "external absolute artifact URI evidence"
      ]
    }
  ],
  "evidence": {
    "contracts": [
      "resources/platform-objective-conformance.json",
      "resources/platform-foundation-task-graph.json",
      "resources/platform-foundation-alignment-audit.json",
      "resources/platform-task-execution-audit.json",
      "resources/platform-goal-completion-audit.json",
      "resources/platform-engineering-capabilities.json",
      "resources/platform-capability-contracts.json",
      "resources/platform-production-readiness.json",
      "resources/platform-deployment-topology.json",
      "resources/platform-node-closeout-audit.json",
      "resources/platform-service-contract-standard.json",
      "resources/platform-service-object-runtime.json",
      "resources/platform-integration-ports.json",
      "resources/platform-organization-rbac-menu-contract.json"
    ],
    "validators": [
      "scripts/validate-platform-objective-conformance.mjs",
      "scripts/validate-platform-foundation-task-graph.mjs",
      "scripts/validate-platform-foundation-alignment.mjs",
      "scripts/validate-platform-task-execution-audit.mjs",
      "scripts/validate-platform-goal-completion-audit.mjs",
      "scripts/validate-platform-node-closeout-audit.mjs",
      "scripts/validate-platform-data-lifecycle-retention.mjs",
      "scripts/validate-platform-sensitive-data-migration.mjs",
      "scripts/validate-platform-service-contract-standard.mjs",
      "scripts/validate-platform-service-object-runtime.mjs",
      "scripts/validate-platform-integration-ports.mjs",
      "scripts/validate-platform-organization-rbac-menu-contract.mjs",
      "scripts/validate-platform-engineering-capabilities.mjs",
      "scripts/validate-platform-capability-contracts.mjs",
      "scripts/validate-platform-production-readiness.mjs",
      "scripts/validate-platform-deployment-topology.mjs"
    ],
    "tests": [
      "scripts/platform-capability-contracts.test.mjs",
      "scripts/platform-foundation-task-graph.test.mjs",
      "scripts/platform-objective-conformance.test.mjs",
      "scripts/platform-foundation-alignment.test.mjs",
      "scripts/platform-goal-completion-audit.test.mjs",
      "scripts/platform-task-execution-audit.test.mjs",
      "scripts/platform-node-closeout-audit.test.mjs",
      "scripts/platform-data-lifecycle-retention.test.mjs",
      "scripts/platform-sensitive-data-migration.test.mjs",
      "scripts/platform-service-contract-standard.test.mjs",
      "scripts/platform-service-object-runtime.test.mjs",
      "scripts/platform-integration-ports.test.mjs",
      "scripts/platform-organization-rbac-menu-contract.test.mjs",
      "scripts/platform-deployment-topology.test.mjs",
      "scripts/platform-engineering-capabilities.test.mjs",
      "scripts/platform-production-readiness.test.mjs",
      "scripts/admin-ui-contracts.test.mjs"
    ],
    "docs": [
      "README.md",
      "AGENTS.md",
      "docs/platform-foundation-task-map.md",
      "docs/platform-roadmap.md",
      "docs/platform-auth.md",
      "docs/platform-deployment.md",
      "docs/admin-resource-schema.md",
      "docs/platform-data-lifecycle-retention.md",
      "docs/platform-service-contract-standard.md",
      "docs/platform-service-objects.md",
      "docs/platform-integration-ports.md",
      "docs/platform-organization-rbac-menu-contract.md",
      "docs/platform-sensitive-data-migration.md",
      "docs/platform-ui-optimization-assessment.md",
      "docs/admin-ui-foundation.md",
      "docs/superpowers/specs/2026-07-13-sensitive-data-reveal-step-up-design.md",
      "docs/superpowers/plans/2026-07-13-sensitive-data-reveal-step-up.md",
      "design-qa.md"
    ]
  }
}
