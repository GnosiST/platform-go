# Copy this file to a private .env file before deployment.
# Do not commit real secrets.

PLATFORM_RUNTIME_ENV=production
PLATFORM_HTTP_ADDR=0.0.0.0:9200
PLATFORM_PUBLIC_BASE_URL=https://platform.example.test
# Keep these aligned with the Compose internal network. Trust only the Admin
# proxy address that connects directly to platform-api.
PLATFORM_INTERNAL_SUBNET=172.30.0.0/24
PLATFORM_ADMIN_PROXY_IP=172.30.0.10
PLATFORM_TRUSTED_PROXIES=172.30.0.10
# Single Docker bridge gateway IP used by the reviewed host-local TLS edge when
# it connects to the loopback-bound Admin origin. CIDRs are not accepted.
PLATFORM_EDGE_TRUSTED_PROXY=172.30.0.1
PLATFORM_HTTP_MAX_BODY_BYTES=1048576
PLATFORM_JWT_SECRET=replace-with-at-least-32-characters-secret
# Initialization-time sensitive-data protection settings. Keep historical key
# entries while any stored envelope references them; never reuse material across
# encryption and blind-index keyrings.
PLATFORM_DATA_KEY_PROVIDER=env-aes256
PLATFORM_DATA_ENCRYPTION_ACTIVE_KEY_ID=enc-v1
PLATFORM_DATA_ENCRYPTION_KEYRING_JSON={"enc-v1":"cmVwbGFjZS13aXRoLWVuY3J5cHRpb24ta2V5LTAwMDE="}
PLATFORM_DATA_BLIND_INDEX_ACTIVE_KEY_ID=idx-v1
PLATFORM_DATA_BLIND_INDEX_KEYRING_JSON={"idx-v1":"cmVwbGFjZS13aXRoLWJsaW5kLWluZGV4LWtleS0wMDE="}
# Required when enabled manifests declare sensitive reveal policies. Generate a
# dedicated random value of at least 32 bytes; do not reuse JWT, phone, code or
# rate-limit HMAC material.
PLATFORM_SENSITIVE_REVEAL_HMAC_KEY=
PLATFORM_CAPABILITIES=tenant,identity,session,rbac,menu,api-resource,audit,wechat-login,admin-oidc,dictionary,parameter,file-storage,admin-shell,system-admin
PLATFORM_DISABLE_DEMO_AUTH_PROVIDER=true

# Set these before enabling app-phone. Generate independent random values and
# treat both HMAC keys as initialization-time settings; rotating them requires
# an explicit migration plan for existing phone bindings.
PLATFORM_PHONE_HMAC_KEY=
PLATFORM_PHONE_CODE_HMAC_KEY=
PLATFORM_PHONE_VERIFICATION_PROVIDER=
# Configure all five fields together when an Admin reveal policy offers SMS.
# The phone field must be recoverably encrypted. The verified digest must bind
# the current phone value to the verification event so a later phone edit does
# not inherit stale verification. The stock API process does not bundle a
# production SMS sender; a downstream composition must register one.
PLATFORM_ADMIN_STEP_UP_PHONE_RESOURCE=
PLATFORM_ADMIN_STEP_UP_PHONE_ACTOR_FIELD=
PLATFORM_ADMIN_STEP_UP_PHONE_FIELD=
PLATFORM_ADMIN_STEP_UP_PHONE_VERIFIED_AT_FIELD=
PLATFORM_ADMIN_STEP_UP_PHONE_VERIFIED_DIGEST_FIELD=

# Optional notification SMS channel. Leave empty unless the notification
# capability is enabled and a downstream composition registers the named
# provider adapter. mock-local is development/test only and is rejected in
# production.
PLATFORM_NOTIFICATION_SMS_PROVIDER=
PLATFORM_NOTIFICATION_SMS_LOGIN_TEMPLATE_ID=

PLATFORM_ADMIN_OIDC_ISSUER_URL=
PLATFORM_ADMIN_OIDC_CLIENT_ID=
PLATFORM_ADMIN_OIDC_CLIENT_SECRET=
PLATFORM_ADMIN_OIDC_REDIRECT_URL=
PLATFORM_ADMIN_OIDC_SCOPES=openid,profile,email

PLATFORM_ADMIN_RESOURCE_DRIVER=mysql
PLATFORM_ADMIN_RESOURCE_DSN=platform:platform_pass@tcp(platform-mysql:3306)/platform?charset=utf8mb4&parseTime=True&loc=Local
PLATFORM_ORGANIZATION_RBAC_MODE=target
# The independent role-menu runtime is present, but serving and writes remain
# on the migration-safe closed settings until the E2E cutover is certified.
PLATFORM_ADMIN_MENU_SERVING_MODE=legacy
PLATFORM_ADMIN_ROLE_MENU_WRITE_ENABLED=false
PLATFORM_SESSION_DRIVER=mysql
PLATFORM_SESSION_DSN=platform:platform_pass@tcp(platform-mysql:3306)/platform?charset=utf8mb4&parseTime=True&loc=Local
PLATFORM_LIFECYCLE_HISTORY_DRIVER=mysql
PLATFORM_LIFECYCLE_HISTORY_DSN=platform:platform_pass@tcp(platform-mysql:3306)/platform?charset=utf8mb4&parseTime=True&loc=Local
# Retention maintenance is destructive and remains disabled by default. Enable
# it only after preparing lifecycle tables, completing impact and dry-run
# evidence, and persisting an exact policy promotion in the Admin database.
PLATFORM_RETENTION_RUNNER_ENABLED=false
PLATFORM_RETENTION_RUNNER_INTERVAL=24h
PLATFORM_RETENTION_RUNNER_BATCH_SIZE=100
PLATFORM_RETENTION_RUNNER_MAX_RETRIES=3

# Optional external integrations are disabled in the stock runtime. Enabling
# either switch also requires a downstream composition to register the named
# adapter; platform-go does not bundle a broker or search engine client here.
PLATFORM_MESSAGE_BUS_ENABLED=false
PLATFORM_MESSAGE_BUS_ADAPTER=
PLATFORM_SEARCH_ENABLED=false
PLATFORM_SEARCH_ADAPTER=

PLATFORM_CACHE_DRIVER=redis
PLATFORM_REDIS_ADDR=platform-redis:6379
PLATFORM_REDIS_PASSWORD=
PLATFORM_REDIS_DB=0
# Generate a dedicated random value of at least 32 bytes. It must not match the
# phone or verification-code HMAC keys.
PLATFORM_RATE_LIMIT_HMAC_KEY=replace-with-dedicated-rate-limit-key

PLATFORM_FILE_STORAGE_DRIVER=local
PLATFORM_FILE_STORAGE_LOCAL_DIR=/app/.platform/uploads
PLATFORM_FILE_MAX_UPLOAD_BYTES=10485760
PLATFORM_FILE_ALLOWED_MIME_TYPES=application/pdf,image/jpeg,image/png,text/plain
PLATFORM_FILE_STORAGE_S3_ENDPOINT=
PLATFORM_FILE_STORAGE_S3_REGION=
PLATFORM_FILE_STORAGE_S3_BUCKET=
PLATFORM_FILE_STORAGE_S3_ACCESS_KEY=
PLATFORM_FILE_STORAGE_S3_SECRET_KEY=
PLATFORM_FILE_STORAGE_S3_PREFIX=
PLATFORM_FILE_STORAGE_S3_FORCE_PATH_STYLE=false
PLATFORM_FILE_STORAGE_S3_SERVER_SIDE_ENCRYPTION=AES256
PLATFORM_FILE_STORAGE_S3_KMS_KEY_ID=

MYSQL_ROOT_PASSWORD=replace-with-private-root-password
MYSQL_DATABASE=platform
MYSQL_USER=platform
MYSQL_PASSWORD=platform_pass
