{
  "name": "platform-go-admin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 9202",
    "i18n": "node ../scripts/validate-admin-i18n.mjs",
    "refine": "node ../scripts/validate-admin-refine-runtime.mjs",
    "refine:crud": "node ../scripts/validate-admin-refine-crud.mjs",
    "ui:contracts": "node ../scripts/validate-admin-ui-contracts.mjs",
    "typecheck": "tsc --noEmit",
    "build": "npm run i18n && npm run refine && npm run refine:crud && npm run ui:contracts && tsc --noEmit && vite build"
  },
  "dependencies": {
    "@ant-design/icons": "^5.6.1",
    "@refinedev/antd": "^6.0.3",
    "@refinedev/core": "^5.0.12",
    "@refinedev/react-router": "^2.0.4",
    "@vitejs/plugin-react": "^6.0.3",
    "antd": "^5.29.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.9.6",
    "react-router-dom": "^7.9.6",
    "vite": "^8.1.3"
  },
  "overrides": {
    "path-to-regexp": "^8.4.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "typescript": "^5.9.3",
    "yaml": "^2.9.0"
  }
}
